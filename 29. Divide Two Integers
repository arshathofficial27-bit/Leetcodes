class Solution {
    public int divide(int dividend, int divisor) {
        // Handle overflow case: MIN_VALUE / -1 overflows int range
        if (dividend == Integer.MIN_VALUE && divisor == -1) {
            return Integer.MAX_VALUE;
        }
        
        // Determine sign of result
        boolean negative = (dividend < 0) ^ (divisor < 0);
        
        // Use long to avoid overflow issues when taking absolute values
        long dvd = Math.abs((long) dividend);
        long dvs = Math.abs((long) divisor);
        
        long result = 0;
        
        // Subtract divisor (scaled by powers of 2) from dividend
        while (dvd >= dvs) {
            long temp = dvs;
            long multiple = 1;
            
            // Double temp until it exceeds dvd, using bit shifts
            while (temp << 1 <= dvd) {
                temp <<= 1;
                multiple <<= 1;
            }
            
            dvd -= temp;
            result += multiple;
        }
        
        return negative ? (int) -result : (int) result;
    }
}
