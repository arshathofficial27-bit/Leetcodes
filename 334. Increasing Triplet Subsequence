class Solution {
    public boolean increasingTriplet(int[] nums) {
        int first = Integer.MAX_VALUE;
        int second = Integer.MAX_VALUE;
        
        for (int num : nums) {
            if (num <= first) {
                first = num;          // update smallest
            } else if (num <= second) {
                second = num;         // update second smallest
            } else {
                return true;          // num > second > first found
            }
        }
        
        return false;
    }
}
